{
  "manifest_version": 3,
  "name": "Article Navigator",
  "version": "1.0.0",
  "description": "Intelligently find and navigate the most relevant paragraphs in any article.",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:8080/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js":  ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}